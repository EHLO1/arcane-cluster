{
    http_port 8080
    https_port 8443
}

{$APP_URL} {
    tls {
        # FORCE Let's Encrypt so the path is predictable
        issuer acme {
            dir https://acme-v02.api.letsencrypt.org/directory
            dns cloudflare {$CLOUDFLARE_API_TOKEN}
        }
    }
    
    respond "Certificate Manager"
}