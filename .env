# ––––––––––––––––––––––––––––––––––––––
# –––––––––––––-  COMMON  –––––––––––––-
# ––––––––––––––––––––––––––––––––––––––

#-[ Image Tags (App Versions)
# Best practice is to pin a specific version, instead of using 'latest'
SOCKET_PROXY_IMAGE_TAG="latest"
POSTGRES_IMAGE_TAG="17"
ARCANE_IMAGE_TAG="latest"
CLOUDFLARED_IMAGE_TAG="latest"
CADDY_IMAGE_TAG="latest"

#-[ Timezone
TZ="America/Chicago"

#-[ Caddy Secrets
CLOUDFLARE_API_TOKEN=${CLOUDFLARE_API_TOKEN}
SSL_EMAIL=${SSL_EMAIL}


# ––––––––––––––––––––––––––––––––––––––
# –––––––––––––  DATABASE  –––––––––––––
# ––––––––––––––––––––––––––––––––––––––

#-[ Postgres
POSTGRES_USER=${ARCANE_POSTGRES_USER}
POSTGRES_PASSWORD=${ARCANE_POSTGRES_PASSWORD}
POSTGRES_DB="arcane"

#-[ Arcane
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@arcane-postgres:5432/${POSTGRES_DB}"


# ––––––––––––––––––––––––––––––––––––––
# –––––––––-–––  ARCANE  –––––––––––-–-–
# ––––––––––––––––––––––––––––––––––––––

#-[ General
# Primary URL
BASE_URL="ac1.jjcasa.net"
APP_URL="https://${BASE_URL}"

#-[ Secrets & Keys
ENCRYPTION_KEY=${ARCANE_ENCRYPTION_KEY}
JWT_SECRET=${ARCANE_JWT_SECRET}

#-[ OIDC
OIDC_ENABLED=true
OIDC_CLIENT_ID=${ARCANE_OIDC_CLIENT_ID}
OIDC_CLIENT_SECRET=${ARCANE_OIDC_CLIENT_SECRET}
OIDC_ISSUER_URL=${ARCANE_OIDC_ISSUER_URL}
OIDC_SCOPES="openid email profile groups"
OIDC_GROUPS_CLAIM="groups"
OIDC_ROLE_MAPPINGS=[{"claimValue":"arcane-admins","roleId":"role_admin"}]
OIDC_PROVIDER_NAME="JJCasa ID"
OIDC_PROVIDER_LOGO_URL="https://cdn.jsdelivr.net/gh/selfhst/icons@main/svg/pocket-id.svg"

#-[ Logging
LOG_LEVEL="info"
LOG_JSON="false"

# ––––––––––––––––––––––––––––––––––––––
# –––––––––––  CLOUDFLARED  ––––––––––––
# ––––––––––––––––––––––––––––––––––––––

#-[ Token
CLOUDFLARE_TUNNEL_TOKEN=${ARCANE_CLOUDFLARE_TUNNEL_TOKEN}